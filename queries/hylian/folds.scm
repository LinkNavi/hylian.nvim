; ── Hylian folds for nvim-treesitter ─────────────────────────────────────────

(func_decl   (block) @fold)
(method_decl (block) @fold)
(ctor_decl   (block) @fold)
(class_decl  (class_body) @fold)
(if_stmt     (block) @fold)
(while_stmt  (block) @fold)
(for_stmt    (block) @fold)
(for_in_stmt (block) @fold)
(switch_stmt @fold)
(unsafe_block @fold)
